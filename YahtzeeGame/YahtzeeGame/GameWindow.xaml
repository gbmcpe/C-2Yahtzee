                                    <Label  Content="{Binding PlayerName}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Background="Chocolate"  Height="15" VerticalAlignment="Center" Padding="3,0,3,0"/>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Aces}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.AcesScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen" />
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Twos}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PlayerScores.TwosScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Threes}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.ThreesScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Fours}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.FoursScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Fives}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.FivesScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Sixes}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.SixesScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Bonus}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.BonusScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.ThreeOfAKind}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.ThreeOfAKindScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.FourOfAKind}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.FourOfAKindScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.FullHouse }" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.FullHouseScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.SmallStraight }" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.SmallStraightScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.LargeStraight}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.LargeStraightScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                                    <Label Content="{Binding PlayerScores.Yahtzee}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.YahtzeeScored}" Value="True">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>
                                </Border>
                                <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,10" Padding="2">
                                    <Label Content="{Binding PlayerScores.Chance}" FontFamily="Berlin Sans FB" FontSize="12" Foreground="Chocolate"  Height="15" VerticalAlignment="Center" Padding="1">
                                        <Label.Style>
                                            <Style TargetType="Label">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding PlayerScores.ChanceScored}" Value="True">
