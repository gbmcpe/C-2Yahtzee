<Window x:Class="YahtzeeGame.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YahtzeeGame"
        mc:Ignorable="d"
        Title="GameWindow" Height="450" Width="911">
    <Grid HorizontalAlignment="Center" Width="911">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFFF8686"/>
                <GradientStop Color="#FF235882" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid Margin="1,-11,-1,-6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="219*"/>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="124*"/>
                <ColumnDefinition Width="274"/>
                <ColumnDefinition Width="177*"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="14,50,61,0" VerticalAlignment="Top" Height="314" Grid.ColumnSpan="3" Width="auto">
                <Grid.ColumnDefinitions>
                    <!--categories-->
                    <ColumnDefinition Width="150"/>
                    <!--players-->
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <!--Columm 1-->
                <StackPanel Grid.Column="0" Orientation="Vertical" Background="Chocolate">
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2" >
                        <Label  Content="Player:" FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Aces: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Twos: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Threes: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Fours: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Fives: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Sixes: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Bonus: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="ThreeOfAKind: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="FourOfAKind: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="FullHouse: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="SmallStraight: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="LargeStraight" FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Yahtzee" FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                    <Border BorderBrush="#FFEFE6D0" BorderThickness="0,0,0,2" Margin="0,0,0,0" Padding="2">
                        <Label Content="Chance: " FontFamily="Berlin Sans FB" FontSize="12" Foreground="#FFEFE6D0" Height="15" VerticalAlignment="Center" Padding="1"/>
                    </Border>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Players}" x:Name="PlayerList" Panel.ZIndex="999" MinWidth="10" MinHeight="400"  HorizontalAlignment="Center"  Grid.Column="1" Background="Chocolate" VerticalAlignment="Top" Height="401" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled" RenderTransformOrigin="0.5,0.5" ScrollViewer.CanContentScroll="True"  >
                    <ItemsControl.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </ItemsControl.RenderTransform>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="0,0,0,0" Background="WhiteSmoke">
