                                        </Label.Style>
                                    </Label>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Button x:Name="BtnClose" Content="Close" HorizontalAlignment="Left" Margin="82,392,0,0" VerticalAlignment="Top" Click="BtnClose_Click" Height="32" Width="72" FontFamily="Berlin Sans FB" FontSize="20" Grid.Column="4"/>
