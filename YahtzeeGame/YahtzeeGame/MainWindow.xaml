<Window x:Class="YahtzeeGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YahtzeeGame"
        mc:Ignorable="d"
        Title="YahtzeeGame" Height="652" Width="1012">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF1A1A1A"/>
            <GradientStop Color="#FF080707" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid HorizontalAlignment="Center" Height="365" Margin="0,215,0,0" VerticalAlignment="Top" Width="516">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="59*"/>
            <ColumnDefinition Width="70*"/>
        </Grid.ColumnDefinitions>
        <ComboBox x:Name="cmbxPlayerType1" Margin="-1,-21,130,259" SelectionChanged="cmbxPlayerType1_SelectionChanged" Foreground="#FF5D2525" BorderBrush="#FFF92323" Background="#FF277D09" MaxHeight="25" MaxWidth="105">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy Computer"/>
            <ComboBoxItem Content="Hard Computer"/>
        </ComboBox>
        <ComboBox x:Name="cmbxPlayerType1_Copy" Margin="-1,103,130,138" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black" MaxHeight="25" MaxWidth="105">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy Computer"/>
            <ComboBoxItem Content="Hard Computer"/>
        </ComboBox>
        <ComboBox x:Name="cmbxPlayerType1_Copy2" Margin="-1,163,130,74" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black" MaxHeight="25" MaxWidth="105">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy CPU"/>
            <ComboBoxItem Content="Hard CPU"/>
        </ComboBox>
        <TextBox x:Name="tbPlayer1" HorizontalAlignment="Left" Margin="210,22,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="255" Height="41" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" TextChanged="tbPlayer1_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C" BorderBrush="#FFF9FBFF" BorderThickness="2,2,2,2" Grid.ColumnSpan="2" IsEnabled="False"/>
        <TextBox x:Name="tbPlayer2" HorizontalAlignment="Left" Margin="210,81,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="255" Height="41" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" TextChanged="tbPlayer2_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C" BorderBrush="White" BorderThickness="2,2,2,2" Grid.ColumnSpan="2" IsEnabled="False"/>
        <TextBox x:Name="tbPlayer3" HorizontalAlignment="Left" Margin="210,142,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="255" Height="41" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer3_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C" BorderBrush="White" BorderThickness="2,2,2,2" Grid.ColumnSpan="2"/>
        <TextBox x:Name="tbPlayer4" HorizontalAlignment="Left" Margin="210,204,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="255" Height="41" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer4_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C" BorderBrush="White" BorderThickness="2,2,2,2" Grid.ColumnSpan="2"/>
        <Label x:Name="lblPlayer1" Content="Player 1" HorizontalAlignment="Left" Margin="125,18,0,0" VerticalAlignment="Top" Width="68" Background="{x:Null}" Height="39" FontSize="16" FontWeight="Medium" VerticalContentAlignment="Center">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5D1616" Offset="0"/>
                    <GradientStop Color="#FFD62A2A" Offset="0.92"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Label x:Name="lblPlayer2" Content="Player 2" HorizontalAlignment="Left" Margin="125,77,0,0" VerticalAlignment="Top" Width="68" Background="{x:Null}" Height="39" FontSize="16" FontWeight="Medium" VerticalContentAlignment="Center">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5D1616"/>
                    <GradientStop Color="#FFD62A2A" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Label x:Name="lblPlayer3" Content="Player 3" HorizontalAlignment="Left" Margin="125,144,0,0" VerticalAlignment="Top" Width="68" Background="{x:Null}" Height="39" FontSize="16" FontWeight="Medium" VerticalContentAlignment="Center">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5D1616"/>
                    <GradientStop Color="#FFD62A2A" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Label x:Name="lblPlayer3_Copy" Content="Player 4" HorizontalAlignment="Left" Margin="125,206,0,0" VerticalAlignment="Top" Width="68" Background="{x:Null}" Height="39" FontSize="16" FontWeight="Medium" VerticalContentAlignment="Center">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5D1616"/>
                    <GradientStop Color="#FFD62A2A" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <ComboBox x:Name="cmbxPlayerType2" Margin="-1,33,130,205" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black" MaxHeight="25" MaxWidth="105">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy Computer"/>
            <ComboBoxItem Content="Hard Computer"/>
        </ComboBox>
        <Label x:Name="lblPlayer1_Roll" Content="" HorizontalAlignment="Left" Margin="248,30,0,0" VerticalAlignment="Top" Height="27" Width="9" Grid.Column="1"/>
        <Label x:Name="lblPlayer2_Roll" Content="" HorizontalAlignment="Left" Margin="248,89,0,0" VerticalAlignment="Top" Height="27" Width="9" Grid.Column="1"/>
        <Label x:Name="lblPlayer3_Roll" Content="" HorizontalAlignment="Left" Margin="252,153,0,0" VerticalAlignment="Top" Height="27" Width="10" Grid.Column="1"/>
        <Label x:Name="lblPlayer4_Roll" Content="" HorizontalAlignment="Left" Margin="252,213,0,0" VerticalAlignment="Top" Height="27" Width="10" Grid.Column="1"/>
        <Grid HorizontalAlignment="Left" Height="75" Margin="-86,-153,0,0" VerticalAlignment="Top" Width="574" Grid.ColumnSpan="2">
            <Label Content="Yahtzee!" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="65" Foreground="#FF8A8989" FontFamily="Tw Cen MT Condensed Extra Bold" Margin="251,-10,0,0"/>
        </Grid>
        <Label Content="Yahtzee!" HorizontalAlignment="Left" Margin="159,-163,0,0" VerticalAlignment="Top" FontSize="65" FontFamily="Tw Cen MT Condensed Extra Bold" Grid.ColumnSpan="2">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6F1C1C"/>
                    <GradientStop Color="#FFC51D1D" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Label Content="Label" HorizontalAlignment="Left" Margin="334,-51,0,0" VerticalAlignment="Top" Grid.Column="1"/>
        <ComboBox x:Name="cmbxPlayers" HorizontalAlignment="Left" Margin="190,-78,0,0" VerticalAlignment="Top" Width="138" Height="29" HorizontalContentAlignment="Center" Grid.ColumnSpan="2">
            <ComboBoxItem Content="Number of Players..." IsSelected="True"/>
            <ComboBoxItem Content="Single Player"/>
            <ComboBoxItem Content="2 Players"/>
            <ComboBoxItem Content="3 Players"/>
            <ComboBoxItem Content="4 Players"/>
        </ComboBox>
        <Button Content="Button" HorizontalAlignment="Left" Height="0" Margin="-18,316,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnRollForPosition" Content="" RenderTransformOrigin="0.5,0.5" Margin="201,290,256,23" Grid.ColumnSpan="2">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleY="-1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
            <Button.BindingGroup>
                <BindingGroup/>
            </Button.BindingGroup>
            <Button.Background>
                <ImageBrush ImageSource="/1Die.bmp" Stretch="Fill"/>
            </Button.Background>
        </Button>
        <Button x:Name="btnStart" Grid.Column="1" Content="Start Game" HorizontalAlignment="Center" Margin="0,290,0,0" VerticalAlignment="Top" Background="#FFF3E9E9" FontWeight="Bold" Foreground="#FFC82323" FontSize="18" Height="51" Width="132"/>
        <Label x:Name="lbldirection" Content="Please click the die&#xD;&#xA;      to roll dice&#xD;&#xA;to decide player order" HorizontalAlignment="Left" Margin="10,270,0,0" VerticalAlignment="Top" Height="72" Width="167" Foreground="#FFF9F2F2" FontWeight="Medium" HorizontalContentAlignment="Center" FontSize="14" VerticalContentAlignment="Center"/>
        <Button x:Name="btnAbout" Content="About" HorizontalAlignment="Left" Margin="148,-78,0,0" VerticalAlignment="Top" Grid.Column="1" FontSize="19" Background="#FF861B1B" Foreground="#FFF5F0F0" FontWeight="DemiBold"/>
        <Button x:Name="btnHighScore" Content="High Score" HorizontalAlignment="Left" Margin="44,-78,0,0" VerticalAlignment="Top" FontSize="19" Background="#FF861B1B" Foreground="White" FontWeight="DemiBold"/>
    </Grid>
</Window>
