<Window x:Class="YahtzeeGame.MultiplayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YahtzeeGame"
        mc:Ignorable="d"
        Title="MultiplayerWindow" Height="658" Width="1039" Background="#FF0A0101">
    <Grid Margin="0,0,62,19">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="713*"/>
            <ColumnDefinition Width="87*"/>
        </Grid.ColumnDefinitions>
        <ComboBox x:Name="cmbxPlayerType1" Margin="16,101,744,492" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy CPU"/>
            <ComboBoxItem Content="Hard CPU"/>
        </ComboBox>
        <ComboBox x:Name="cmbxPlayerType1_Copy" Margin="16,228,744,368" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy CPU"/>
            <ComboBoxItem Content="Hard CPU"/>
        </ComboBox>
        <ComboBox x:Name="cmbxPlayerType1_Copy2" Margin="16,285,744,307" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy CPU"/>
            <ComboBoxItem Content="Hard CPU"/>
        </ComboBox>
        <Button x:Name="btnRollForPosition" Content="" HorizontalAlignment="Left" Margin="552,376,0,0" VerticalAlignment="Top" Height="44" Width="46" FontSize="30" FontFamily="Berlin Sans FB" Foreground="#FF630A0A" Click="btnRollPos_Click" IsDefault="True">
            <Button.Background>
                <ImageBrush ImageSource="/6Die.bmp"/>
            </Button.Background>
        </Button>
        <Label x:Name="lblRollForPosition_Copy" HorizontalAlignment="Left" Margin="253,362,0,0" VerticalAlignment="Top" FontFamily="Arial Rounded MT Bold" Width="245" Height="73" ClipToBounds="True" FontSize="16" Foreground="#FFFBF8F8">
            <Button Content="Button"/>
        </Label>
        <TextBox x:Name="tbPlayer1" HorizontalAlignment="Left" Margin="234,97,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264" Height="40" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer1_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C"/>
        <TextBox x:Name="tbPlayer2" HorizontalAlignment="Left" Margin="234,155,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264" Height="40" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer2_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C"/>
        <TextBox x:Name="tbPlayer3" HorizontalAlignment="Left" Margin="234,215,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264" Height="40" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer3_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C"/>
        <TextBox x:Name="tbPlayer4" HorizontalAlignment="Left" Margin="234,276,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264" Height="40" FontFamily="Berlin Sans FB" FontSize="30" TextAlignment="Center" IsEnabled="False" TextChanged="tbPlayer4_TextChanged" Foreground="#FFB72727" Background="#FFE63C3C"/>
        <Button x:Name="btnStart" Content="Start Game" HorizontalAlignment="Left" Margin="361,469,0,0" VerticalAlignment="Top" Height="40" Width="164" FontSize="30" FontFamily="Berlin Sans FB" Background="#FFEFF665" Foreground="#FF630A0A" Click="btnStart_Click" IsDefault="True" IsEnabled="False"/>
        <Label x:Name="lblPlayer1" Content="Player 1" HorizontalAlignment="Left" Margin="146,93,0,0" VerticalAlignment="Top" Width="70" Background="{x:Null}" Height="38" FontSize="13" FontWeight="Medium" VerticalContentAlignment="Center" Foreground="#FFD4FDCE"/>
        <Label x:Name="lblPlayer2" Content="Player 2" HorizontalAlignment="Left" Margin="146,151,0,0" VerticalAlignment="Top" Width="70" Background="{x:Null}" Height="38" FontSize="13" FontWeight="Medium" VerticalContentAlignment="Center" Foreground="#FFD4FDCE"/>
        <Label x:Name="lblPlayer3" Content="Player 3" HorizontalAlignment="Left" Margin="146,217,0,0" VerticalAlignment="Top" Width="70" Background="{x:Null}" Height="38" FontSize="13" FontWeight="Medium" VerticalContentAlignment="Center" Foreground="#FFD4FDCE"/>
        <Label x:Name="lblPlayer3_Copy" Content="Player 4" HorizontalAlignment="Left" Margin="146,278,0,0" VerticalAlignment="Top" Width="70" Background="{x:Null}" Height="38" FontSize="13" FontWeight="Medium" VerticalContentAlignment="Center" Foreground="#FFD4FDCE"/>
        <ComboBox x:Name="cmbxPlayerType2" Margin="16,159,744,434" SelectionChanged="cmbxPlayerType1_SelectionChanged" Background="Black">
            <ComboBox Height="38" Width="2"/>
            <ComboBoxItem Content="Player Type . . ." IsSelected="True"/>
            <ComboBoxItem Content="Human"/>
            <ComboBoxItem Content="Easy CPU"/>
            <ComboBoxItem Content="Hard CPU"/>
        </ComboBox>
        <Label x:Name="lblPlayer1_Roll" Content="" HorizontalAlignment="Left" Margin="688,206,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblPlayer2_Roll" Content="" HorizontalAlignment="Left" Margin="688,264,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblPlayer3_Roll" Content="" HorizontalAlignment="Left" Margin="693,327,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblPlayer4_Roll" Content="" HorizontalAlignment="Left" Margin="693,386,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cmbxPlayers" HorizontalAlignment="Left" Margin="244,37,0,0" VerticalAlignment="Top" Width="120"/>

    </Grid>
</Window>
